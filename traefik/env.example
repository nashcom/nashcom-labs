DOMAIN=example.com

# Optional: basic auth for the Traefik dashboard (generate with: htpasswd -nB admin)
# DASHBOARD_AUTH=admin:$2y$05$...

# Optional: ACME CA server. Defaults to Let's Encrypt staging (untrusted
# certs, higher rate limits) when unset. Switch to production once the
# flow is confirmed working:
# ACME_CASERVER=https://acme-v02.api.letsencrypt.org/directory
